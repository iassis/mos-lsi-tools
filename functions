#!/bin/bash

install_plugin() {
    echo "Starting installation of LSI HBA tools..."

    # Create working directory
    mkdir -p /tmp/lsi_setup
    cd /tmp/lsi_setup

    # 1. Install StorCLI (v007.3703)
    echo "Downloading and extracting StorCLI..."
    wget -q -O storcli.zip "https://docs.broadcom.com/docs-and-downloads/007.3703.0000.0000_MR%207.37_Storcli.zip"
    
    # Extract the .deb storcli
    unzip -q -j storcli.zip "*storcli*_all.deb"
    
    # Unpack the deb package
    dpkg-deb -x storcli_007.3703.0000.0000_all.deb ./extracted_deb
    
    # Move the binary
    cp ./extracted_deb/opt/MegaRAID/storcli/storcli64 /usr/sbin/storcli64
    chmod +x /usr/sbin/storcli64
    echo "storcli64 installed successfully."

    # Wipe working directory
    rm -rf /tmp/lsi_setup/*

    # 2. Install sas3flash (P15)
    echo "Downloading and extracting sas3flash..."
    wget -q -O sas3flash.zip "https://docs.broadcom.com/docs-and-downloads/host-bus-adapters/host-bus-adapters-common-files/sas_sata_12g_p15/SAS3FLASH_P15.zip"
    
    # Extract the binary
    unzip -q -j sas3flash.zip "*linux_x64_rel/sas3flash"
    
    cp sas3flash /usr/sbin/sas3flash
    chmod +x /usr/sbin/sas3flash
    echo "sas3flash installed successfully."

    # Wipe working directory
    rm -rf /tmp/lsi_setup/*

    # 3. Install MegaCLI
    echo "Downloading and extracting MegaCLI..."
    wget -q -O megacli.zip "https://docs.broadcom.com/docs-and-downloads/raid-controllers/raid-controllers-common-files/8-07-14_MegaCLI.zip"
    
    # Unzip the megacli64 binary
    unzip -q -j megacli.zip "*MegaCli64.zip"
    unzip -q -j MegaCli64.zip "MegaCli64"
    
    cp MegaCli64 /usr/sbin/megacli64
    chmod +x /usr/sbin/megacli64
    echo "megacli64 installed successfully."

    # Cleanup
    rm -rf /tmp/lsi_setup
    echo "All LSI HBA tools deployment complete!"
}

uninstall_plugin() {
    echo "Removing LSI HBA tools..."
    
    rm -f /usr/sbin/storcli64
    rm -f /usr/sbin/sas3flash
    rm -f /usr/sbin/megacli64
    
    echo "LSI HBA tools removed cleanly."
}

case "$1" in
    install)
        install_plugin
        ;;
    uninstall)
        uninstall_plugin
        ;;
    *)
        echo "Usage: $0 {install|uninstall}"
        exit 1
        ;;
esac
