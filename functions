#!/bin/bash

install_plugin() {
    echo "Starting installation of LSI HBA tools..."

    # 1. Create a temporary working directory
    mkdir -p /tmp/lsi_setup
    cd /tmp/lsi_setup

    # 2. Download the latest StorCLI from Broadcom as of 13th July 2026
    echo "Downloading StorCLI..."
    wget -q -O storcli.zip "https://docs.broadcom.com/docs-and-downloads/007.3703.0000.0000_MR%207.37_Storcli.zip"
    
    # 3. Extract the specific Ubuntu .deb package
    echo "Extracting StorCLI..."
    unzip -q -j storcli.zip "Unified_storcli_all_os/Ubuntu/storcli_007.3703.0000.0000_all.deb" -d /tmp/lsi_setup/
    
    # 4. Unpack the .deb file to get the raw binaries
    ar p storcli_007.3703.0000.0000_all.deb data.tar.xz | tar xJ -C /tmp/lsi_setup
    
    # 5. Move the binary into the system path
    echo "Installing storcli64 to system path..."
    cp /tmp/lsi_setup/opt/MegaRAID/storcli/storcli64 /usr/sbin/storcli64
    
    # 6. Make the binary executable
    chmod +x /usr/sbin/storcli64

    # 7. Clean up temporary files
    rm -rf /tmp/lsi_setup
    
    echo "LSI HBA tools installed successfully!"
}

uninstall_plugin() {
    echo "Removing LSI HBA tools..."
    
    # Delete the binary from the system
    rm -f /usr/sbin/storcli64
    
    echo "LSI HBA tools removed."
}

# MOS hook logic
case "$1" in
    install)
        install_plugin
        ;;
    uninstall)
        uninstall_plugin
        ;;
    *)
        echo "Usage: $0 {install|uninstall}"
        exit 1
        ;;
esac
